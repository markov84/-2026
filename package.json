{
  "name": "kondor-lighting-store-management",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "test": "npm run test --workspace client",
    "serve:client": "npm run build --workspace client && npm run serve:spa --workspace client",
    "seed": "npm run seed --workspace server",
    "seed:demo": "npm run seed:demo --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
